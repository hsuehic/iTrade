# Dependencies
node_modules/
.pnpm-store/

# Build outputs
dist/
build/
*.tsbuildinfo

# Compiled JS artifacts that must never land in src/ directories.
# These are generated by running tsc without an outDir; output should go to dist/ only.
packages/*/src/**/*.js
packages/*/src/**/*.js.map
packages/*/src/**/*.d.ts
packages/*/src/**/*.d.ts.map
apps/*/src/**/*.js
apps/*/src/**/*.js.map
apps/*/src/**/*.d.ts
apps/*/src/**/*.d.ts.map

# Environment files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.development
.env.production
.env.test
.env.gce
.env.*

# Local env files for GCE deployment (filled-in copies of deploy/env.*.template)
deploy/envs/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Coverage directory used by tools like istanbul
coverage/
*.lcov

# IDE files
.idea/
*.swp
*.swo


# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Trading specific
trading-data/
backtest-results/
strategies-private/
api-keys/

# Cache
.cache/
.turbo/
.next/

*firebase-admin.json
apps/web/firebase-service-account.json
apps/mobile/macos/Flutter/ephemeral/Flutter-Generated.xcconfig
apps/mobile/macos/Flutter/ephemeral/flutter_export_environment.sh
