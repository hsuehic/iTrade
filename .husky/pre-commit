#!/usr/bin/env sh

# Cursor/GUI git clients may not load shell profile files, so Node can be
# missing from PATH when hooks run. Bootstrap common locations first.
if ! command -v node >/dev/null 2>&1; then
  export PATH="/opt/homebrew/bin:/usr/local/bin:$PATH"
fi

if ! command -v node >/dev/null 2>&1; then
  export NVM_DIR="${NVM_DIR:-$HOME/.nvm}"
  if [ -s "$NVM_DIR/nvm.sh" ]; then
    . "$NVM_DIR/nvm.sh"
    nvm use --silent >/dev/null 2>&1 || true
  fi
fi

if ! command -v node >/dev/null 2>&1; then
  echo "husky pre-commit: node not found. Install Node or configure ~/.config/husky/init.sh"
  exit 127
fi

# Some FUSE/network-mounted filesystems do not support unlink(). Git creates
# *.lock files throughout .git/ and tries to clean them up with unlink() when
# done; on these filesystems the cleanup silently fails, leaving stale lock
# files that break subsequent git operations (they fail with "File exists").
# The workaround: rename stale *.lock files (rename() works even when
# unlink() doesn't) before and after lint-staged so each git sub-operation
# starts with a clean lock state.
_clear_stale_git_locks() {
  GIT_DIR="$(git rev-parse --git-dir 2>/dev/null)" || return 0
  # Top-level .git/*.lock files (index.lock, MERGE_HEAD.lock, etc.)
  for f in "$GIT_DIR"/*.lock; do
    [ -f "$f" ] && mv "$f" "${f}.stale" 2>/dev/null || true
  done
  # refs/*.lock files (refs/stash.lock, refs/heads/*.lock, etc.)
  find "$GIT_DIR/refs" -name "*.lock" 2>/dev/null | while read -r f; do
    [ -f "$f" ] && mv "$f" "${f}.stale" 2>/dev/null || true
  done
}

_clear_stale_git_locks

# ── Secret detection (Gitleaks) ───────────────────────────────
# Scan only the staged diff, not the full history, to keep pre-commit fast.
# Gitleaks is optional: if not installed, print a warning and skip.
# To install: brew install gitleaks  OR  https://github.com/gitleaks/gitleaks
_run_gitleaks() {
  if ! command -v gitleaks >/dev/null 2>&1; then
    echo "⚠️  gitleaks not found — secret scanning skipped."
    echo "   Install with: brew install gitleaks"
    echo "   Or: https://github.com/gitleaks/gitleaks/releases"
    return 0
  fi

  # Protect runs: scan the git staged diff only (fast, no network)
  gitleaks protect \
    --staged \
    --config=.gitleaks.toml \
    --redact \
    --no-banner \
    --exit-code=1
  local GL_STATUS=$?

  if [ $GL_STATUS -ne 0 ]; then
    echo ""
    echo "❌ Gitleaks detected potential secrets in staged files."
    echo "   Review the findings above before committing."
    echo "   To bypass in an emergency: git commit --no-verify"
    echo "   (But first confirm the detected value is NOT a real secret.)"
    return 1
  fi

  echo "✅ Gitleaks: no secrets detected in staged files"
  return 0
}

_run_gitleaks
GITLEAKS_STATUS=$?

if [ $GITLEAKS_STATUS -ne 0 ]; then
  _clear_stale_git_locks
  exit $GITLEAKS_STATUS
fi

# ── Lint-staged (eslint + prettier) ──────────────────────────
# --no-stash: skip the backup/restore stash that lint-staged normally creates.
# The stash mechanism requires unlink() for lock-file cleanup, which fails on
# FUSE/network-mounted filesystems (EPERM). Since we only ever have fully-staged
# files at commit time, skipping the stash is safe.
lint-staged --no-stash
STATUS=$?
# Clean up any locks lint-staged's git sub-operations left behind.
_clear_stale_git_locks
exit $STATUS
