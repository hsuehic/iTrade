# =============================================================
# iTrade Web Application Environment
# =============================================================
# Copy to: /opt/itrade/.env.web
# This file is read by the 'web' service in docker-compose.prod.yml
# Values here are ONLY available server-side (Next.js API routes / Server Components).
# NEVER put NEXT_PUBLIC_* secrets here.
# =============================================================

# ── Runtime ───────────────────────────────────────────────────
NODE_ENV=production
BUILD_MODE=prod
PORT=3002
HOSTNAME=0.0.0.0

# ── Database ──────────────────────────────────────────────────
# Use Docker service name 'db' as host (internal Docker network)
DB_HOST=db
DB_PORT=5432
DB_USER=itrade
DB_PASSWORD=change_me_strong_password
DB_DB=itrade
DB_SSL=false

# ── Auth (better-auth) ────────────────────────────────────────
# Generate: openssl rand -hex 32
BETTER_AUTH_SECRET=change_me_generate_with_openssl_rand_hex_32
BETTER_AUTH_URL=https://itrade.ihsueh.com   # Your public domain

# ── Google OAuth ──────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ── Apple OAuth (if used) ─────────────────────────────────────
# APPLE_CLIENT_ID=your_apple_client_id
# APPLE_CLIENT_SECRET=your_apple_client_secret

# ── Email (Nodemailer) ────────────────────────────────────────
# EMAIL_SERVER_HOST=smtp.gmail.com
# EMAIL_SERVER_PORT=587
# EMAIL_SERVER_USER=your_email@gmail.com
# EMAIL_SERVER_PASSWORD=your_app_password
# EMAIL_FROM=iTrade <noreply@itrade.ihsueh.com>

# ── Firebase Admin (push notifications) ──────────────────────
# FIREBASE_ADMIN_CREDENTIAL=<base64 encoded service account JSON>

# ── Public runtime config (safe to expose to browser) ─────────
NEXT_PUBLIC_APP_URL=https://itrade.ihsueh.com
