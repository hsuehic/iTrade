# =============================================================
# iTrade Console (Trading Engine) Environment
# =============================================================
# Copy to: /opt/itrade/.env.console
# This file is read by the 'console' service in docker-compose.prod.yml
# Values here are ONLY available inside the console container.
# =============================================================

# ── Database ──────────────────────────────────────────────────
# Use Docker service name 'db' as host (internal Docker network)
DB_HOST=db
DB_PORT=5432
DB_USER=itrade
DB_PASSWORD=change_me_strong_password
DB_DB=itrade
DB_SSL=false

# ── Security ──────────────────────────────────────────────────
# Generate a strong random key: openssl rand -hex 32
ENCRYPTION_KEY=change_me_generate_with_openssl_rand_hex_32

# ── Polling / sync intervals (milliseconds) ───────────────────
BOT_REFRESH_INTERVAL_MS=60000
ACCOUNT_POLLING_INTERVAL=60000
STRATEGY_SYNC_INTERVAL_MS=60000
OPEN_ORDERS_SYNC_INTERVAL=60000

# ── (Optional) Push notifications ────────────────────────────
# FIREBASE_SERVICE_ACCOUNT_JSON=/path/to/serviceAccount.json
