# =============================================================
# Certbot / SSL Certificate Environment Variables
# =============================================================
# Copy to /opt/itrade/.env.certbot and fill in real values.
#
# DOMAIN can be auto-extracted from NEXT_PUBLIC_APP_URL:
#   e.g.  NEXT_PUBLIC_APP_URL=https://itrade.ihsueh.com
#         → DOMAIN=itrade.ihsueh.com
# =============================================================

# Domain to issue the certificate for (no protocol, no trailing slash)
DOMAIN=itrade.ihsueh.com

# Email for Let's Encrypt expiry notifications
CERTBOT_EMAIL=xiaoweihsueh@gmail.com
