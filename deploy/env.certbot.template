# =============================================================
# Certbot / SSL Certificate Environment Variables
# =============================================================
# Copy to /opt/itrade/.env.certbot and fill in real values.
#
# Multiple domains: comma-separated, no spaces, no protocol.
# The FIRST domain is used as the certificate name (cert-name).
# All domains share a single SAN certificate.
#
# Example:
#   DOMAINS=bot.ihsueh.com,itrade.ihsueh.com
# =============================================================

# Domains to issue the certificate for (comma-separated, no protocol)
# Legacy: DOMAIN= (single) is also supported for backward compatibility.
DOMAINS=bot.ihsueh.com,itrade.ihsueh.com

# Email for Let's Encrypt expiry notifications
CERTBOT_EMAIL=xiaoweihsueh@gmail.com
